# BillionCore BIN Engine — environment variables
# Copy to .env and adjust, or set directly in your process manager / Docker.

# ── HTTP ──────────────────────────────────────────────────────────────────
BIN_PORT=8083

# ── API Key hot-reload ────────────────────────────────────────────────────
# Path where Laravel writes valid_keys.json (must match ENGINE_KEYS_FILE_PATH
# in the Laravel .env on the same host / shared volume).
KEYS_FILE_PATH=/tmp/billioncore_valid_keys.json

# How often the engine re-reads the keys file.
# Should match ENGINE_KEYS_SYNC_INTERVAL_SECONDS in Laravel .env.
KEYS_RELOAD_INTERVAL=30s

# ── Usage log shipping ────────────────────────────────────────────────────
# Full URL of the Laravel log-ingestion endpoint.
# Leave empty to disable shipping (useful in dev without Laravel running).
LOG_INGEST_URL=http://localhost:8085/api/internal/logs/ingest

# Must match LOG_INGESTION_SECRET in Laravel .env.
LOG_INGEST_SECRET=bc_internal_log_secret_change_me

# Max log lines per HTTP POST to Laravel (must be ≤ log_ingestion_batch_size).
LOG_BATCH_SIZE=100

# How often to flush the batch even if LOG_BATCH_SIZE is not reached.
LOG_FLUSH_INTERVAL=5s

# ── Debug logging ─────────────────────────────────────────────────────────
# Set to "false" to silence per-request debug logs (stdout).
# Usage logs (usagelog) are always active when LOG_INGEST_URL is set.
BIN_LOGGING_ENABLED=true
